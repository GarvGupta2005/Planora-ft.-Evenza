PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smart_event_management
CLIENT_URL=http://127.0.0.1:3000,http://127.0.0.1:5500,http://localhost:3000,http://localhost:5500
SOCKET_CORS_ORIGIN=http://127.0.0.1:3000,http://127.0.0.1:5500,http://localhost:3000,http://localhost:5500

# JWT
JWT_SECRET=dev_only_change_me_in_production
JWT_EXPIRES_IN=7d

# Node env
NODE_ENV=development

# Firebase (push notifications — optional, leave blank to skip)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"